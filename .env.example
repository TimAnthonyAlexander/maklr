########################################
# Application Settings
########################################

# The display name of your application
APP_NAME=Maklr

# Environment type: local, staging, production
APP_ENV=local

# Enable/disable debug mode (shows detailed error messages)
APP_DEBUG=true

# Base URL and server binding
APP_URL=http://127.0.0.1:7273
APP_HOST=127.0.0.1
APP_PORT=7273

APP_RESPONSE_TIME=false

########################################
# CORS (Cross-Origin Resource Sharing)
########################################

# Comma-separated list of allowed origins for API access
# Example: http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWLIST=http://localhost:7272,http://127.0.0.1:7272

########################################
# Database Configuration
########################################

# Database driver: sqlite, mysql, postgresql
DB_DRIVER=sqlite

# Database name or file (for SQLite, this is a file path)
DB_NAME=database.sqlite


########################################
# MySQL / PostgreSQL (example settings)
########################################

# Uncomment and adjust if using MySQL or PostgreSQL
# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306        # Use 5432 for PostgreSQL
# DB_NAME=maklr
# DB_USER=maklr
# DB_PASSWORD=secret


########################################
# Cache Configuration
########################################

# Default cache driver: array, file, redis
CACHE_DRIVER=file

# Cache key prefix (prevents collisions in shared environments)
CACHE_PREFIX=maklr_cache

# Default cache TTL in seconds (3600 = 1 hour)
CACHE_DEFAULT_TTL=3600

# File cache path (defaults to storage/cache)
# CACHE_PATH=storage/cache

# Enable HTTP response caching middleware
CACHE_RESPONSES=false

# Default TTL for response cache in seconds
CACHE_RESPONSE_TTL=600


########################################
# Redis Cache Configuration
########################################

# Uncomment if using CACHE_DRIVER=redis
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_CACHE_DB=1


########################################
# Queue Configuration
########################################

# Queue driver: sync (development), database (production)
QUEUE_DRIVER=sync


########################################
# Migrations
########################################
MIGRATIONS_FILE=storage/migrations.json


# ===========================
# Request & Upload Limits
# ===========================
REQUEST_MAX_JSON_MB=2
UPLOAD_MAX_MB=25
UPLOAD_ALLOWED_MIME=image/jpeg,image/png,application/pdf

# ===========================
# Session Configuration
# ===========================
SESSION_NAME=MAKLRSESSID
SESSION_SAMESITE=Lax
SESSION_SECURE=false

# ===========================
# Internationalization (i18n)
# ===========================
I18N_DEFAULT_LOCALE=en
I18N_LOCALES=en,de,fr,es,nl,zh
I18N_PROVIDER=deepl

# ===========================
# API Keys
# ===========================
DEEPL_API_KEY=
# OpenAI Responses API Configuration
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-5.1-mini
OPENAI_TEMPERATURE=1.0
OPENAI_MAX_TOKENS=1000

# ===========================
# Rate Limiting
# ===========================
RATE_LIMIT_DIR=storage/ratelimits

########################################
# Encryption
########################################

# 32-byte hex key for encrypting secrets at rest (generate with: php -r "echo bin2hex(random_bytes(32));")
APP_ENCRYPTION_KEY=1bda6eef2436618b845c5cdd7aa8bcb0d5b2925f325516fbee0aa89c8e9b686a

########################################
# Logging Configuration
########################################

# Logging channel: file (writes to storage/logs), stderr (writes to error log)
LOG_CHANNEL=file

# Minimum log level: debug, info, warn, error
LOG_LEVEL=debug

# Log file path (relative to application root)
LOG_FILE=storage/logs/maklr.log
